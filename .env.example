# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=

NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk (written by `clerk init` / `clerk env pull`)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Clerk Frontend API URL — also set on the Convex deployment:
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-instance.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# Optional: document Convex dashboard env vars (set via `npx convex env set`)
# SITE_URL=http://localhost:3000
# AUTH_ALLOWED_EMAILS=moniquemcintosh1234@gmail.com,mgrant90@gmail.com
